# =============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o .env para o git — ele está no .gitignore.
# No Vercel: configure cada variável em Project > Settings > Environment Variables.
# =============================================================

# ----- Gateway BuckPay (ativo) --------------------------------
BUCKPAY_API_URL=https://api.buckpay.com.br
BUCKPAY_API_TOKEN=SEU_TOKEN_BUCKPAY_AQUI
BUCKPAY_USER_AGENT=EstacaoDoHexa/1.0

# ----- Gateway Primecash (legado) -----------------------------
PRIMECASH_API_URL=https://api.primecash.com.br
PRIMECASH_API_KEY=SUA_CHAVE_PRIMECASH_AQUI

# ----- UTMify ------------------------------------------------
UTMIFY_TOKEN=SEU_TOKEN_UTMIFY_AQUI

# ----- Meta Conversions API (CAPI) ---------------------------
META_CAPI_ACCESS_TOKEN=SEU_ACCESS_TOKEN_META_AQUI
# Múltiplos pixels separados por vírgula
META_PIXEL_IDS=1341814591174640
META_API_VERSION=v20.0

# ----- CORS --------------------------------------------------
# Em produção (projeto único) CORS não é necessário (mesmo domínio).
# Útil apenas para dev local se apontar para outro origin.
ALLOWED_ORIGIN=*
